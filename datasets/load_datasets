import pandas as pd
df = pd.read_csv("datasets/titanic/titanic.csv")
# Rename target
df.rename(columns={"Survived": "target"}, inplace=True)
# Drop high-cardinality / useless columns
df = df.drop(columns=["Name", "Ticket", "Cabin"])
# Fill missing
df["Age"] = df["Age"].fillna(df["Age"].median())
df["Embarked"] = df["Embarked"].fillna(df["Embarked"].mode()[0])
# Save cleaned dataset
df.to_csv("datasets/titanic/titanic.csv", index=False)
print("Saved datasets/titanic/titanic.csv")
EOF

