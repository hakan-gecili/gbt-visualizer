python - << 'EOF'
import pandas as pd
from pandas.api.types import is_numeric_dtype
# Column names from adult.names
columns = [
    "age", "workclass", "fnlwgt", "education", "education_num",
    "marital_status", "occupation", "relationship", "race", "sex",
    "capital_gain", "capital_loss", "hours_per_week", "native_country",
    "income"
]

df = pd.read_csv(
    "datasets/adult_income/adult.csv",
    names=columns,
    na_values="?",
    skipinitialspace=True
)
# Clean string-like columns

for col in df.columns:

    if not is_numeric_dtype(df[col]):

        df[col] = df[col].astype("string").str.strip()

# Create binary target

df["target"] = (df["income"] == ">50K").astype(int)

df = df.drop(columns=["income"])

# Fill missing values safely
for col in df.columns:
    if is_numeric_dtype(df[col]):
        df[col] = df[col].fillna(df[col].median())
    else:
        df[col] = df[col].fillna("Unknown")

# Optional: drop noisy sample-weight-like column
# df = df.drop(columns=["fnlwgt"])
df.to_csv("datasets/adult_income/adult_income.csv", index=False)
print("Saved datasets/adult_income/adult_income.csv")
print(df.dtypes)
print(df.head())
EOF


